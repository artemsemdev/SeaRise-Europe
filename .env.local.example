# =============================================================================
# SeaRise Europe — Local Environment Variables
# =============================================================================
# Copy this file to .env.local before running Docker Compose:
#   cp .env.local.example .env.local
#
# .env.local is gitignored — secrets are never committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Geocoding (ADR-019: Azure Maps Search)
# ---------------------------------------------------------------------------
# Required for geocoding API calls in the api container.
# Obtain from Azure Portal → Azure Maps account → Authentication → Primary Key.
# Leave empty to skip geocoding during early local development.
GEOCODING_API_KEY=

# ---------------------------------------------------------------------------
# Basemap (ADR-020: Azure Maps Light)
# ---------------------------------------------------------------------------
# Azure Maps style URL including your subscription key.
# Obtain from Azure Portal → Azure Maps account → Authentication → Primary Key.
# Uses the same Azure Maps account as geocoding (ADR-019).
# Leave empty to use the CARTO Dark fallback during early local development.
BASEMAP_STYLE_URL=
