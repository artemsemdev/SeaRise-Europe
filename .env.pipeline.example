# =============================================================================
# SeaRise Europe — Pipeline Environment Variables
# =============================================================================
# Copy this file to .env.pipeline before running the pipeline:
#   cp .env.pipeline.example .env.pipeline
#
# .env.pipeline is gitignored — secrets are never committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure Blob Storage (Azurite for local development)
# ---------------------------------------------------------------------------
# Local Azurite well-known connection string (not a secret — dev only):
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1

# ---------------------------------------------------------------------------
# PostgreSQL (local Docker Compose instance)
# ---------------------------------------------------------------------------
# Local dev credentials (not secrets — matches docker-compose.yml):
POSTGRES_CONNECTION_STRING=host=localhost port=5432 dbname=searise user=searise password=dev

# ---------------------------------------------------------------------------
# Pipeline working directories (relative to repo root)
# ---------------------------------------------------------------------------
DOWNLOAD_DIR=data/raw
WORK_DIR=data/work
OUTPUT_DIR=data/output
